        "def get_scheduled_rebalance_dates(\n",
        "    start_date: Union[str, pd.Timestamp],\n",
        "    end_date: Union[str, pd.Timestamp],\n",
        "    calendar: str = \"XBOM\", # Indian market calendar\n",
        ") -> List[pd.Timestamp]:\n",
        "\n",
        "    start_date = pd.to_datetime(start_date)\n",
        "    end_date = pd.to_datetime(end_date)\n",
        "\n",
        "    candidates = pd.date_range(start=start_date, end=end_date, freq=\"ME\")\n",
        "    candidates = [d for d in candidates if d.month in [5, 11]] # this is for the may and nov rebalancing\n",
        "\n",
        "    dates = []\n",
        "\n",
        "    for d in candidates:\n",
        "        try:\n",
        "            business_day = get_business_day_offset(d, 0, calendar=calendar)\n",
        "        except Exception:\n",
        "            business_day = d + pd.offsets.BDay(0)\n",
        "\n",
        "        dates.append(pd.to_datetime(business_day).normalize())\n",
        "\n",
        "    return dates\n",
        "\n",
        "\n",
        "def get_all_rebalance_dates(\n",
        "    scheduled_dates: Iterable[pd.Timestamp],\n",
        "    adhoc_dates: Iterable[pd.Timestamp],\n",
        ") -> List[pd.Timestamp]:\n",
        "\n",
        "    all_dates = list(scheduled_dates) + list(adhoc_dates)\n",
        "    return sorted(list(set(pd.to_datetime(all_dates))))\n",
        "\n",
        "\n",
        "def build_ranked_universe(\n",
        "    scores: pd.DataFrame,\n",
        "    parent_weights: pd.Series,\n",
        "    issuer_map: Optional[Dict[str, str]] = None,\n",
        ") -> pd.DataFrame:\n",
        "\n",
        "    ranked = scores.join(\n",
        "        parent_weights.rename(\"Parent Weight\"),\n",
        "        how=\"inner\"\n",
        "    )\n",
        "\n",
        "\n",
        "    ranked = ranked.dropna(\n",
        "        subset=[\"Parent Weight\", \"Final Z Score\", \"Momentum Score\"]\n",
        "    )\n",
        "\n",
        "\n",
        "\n",
        "    # Rank securities by:\n",
        "    # 1. Higher Final Z Score\n",
        "    # 2. Higher Parent Weight (tie-breaker)\n",
        "    ranked = ranked.sort_values(\n",
        "        [\"Final Z Score\", \"Parent Weight\"],\n",
        "        ascending=[False, False]\n",
        "    )\n",
        "\n",
        "    # Assign ranks\n",
        "    ranked[\"Momentum Rank\"] = np.arange(1, len(ranked) + 1)\n",
        "\n",
        "    # Optional issuer mapping\n",
        "    if issuer_map:\n",
        "        ranked[\"Issuer\"] = ranked.index.map(\n",
        "            lambda x: issuer_map.get(x, x)\n",
        "        )\n",
        "\n",
        "    return ranked\n",
        "\n",
        "# This is the portfolio construction function which applies all the previously constructed function here\n",
        "def select_and_weight_portfolio(\n",
        "    scores: pd.DataFrame,\n",
        "    parent_weights: pd.Series,\n",
        "    previous_holdings: Iterable[str],\n",
        "    previous_fixed_numsec: Optional[int] = None,\n",
        "    previous_parent_numsec: Optional[int] = None,\n",
        "    issuer_map: Optional[Dict[str, str]] = None,\n",
        ") -> Tuple[pd.DataFrame, int]:\n",
        "\n",
        "    ranked = build_ranked_universe(\n",
        "        scores=scores,\n",
        "        parent_weights=parent_weights,\n",
        "        issuer_map=issuer_map,\n",
        "    )\n",
        "\n",
        "    parent_numsec = len(parent_weights.dropna())\n",
        "\n",
        "    if previous_fixed_numsec is None or previous_parent_numsec is None:\n",
        "        fixed_numsec = determine_fixed_numsec_initial(\n",
        "            ranked_universe=ranked,\n",
        "            parent_numsec=parent_numsec,\n",
        "        )\n",
        "    else:\n",
        "        fixed_numsec = determine_fixed_numsec_ongoing(\n",
        "            ranked_universe=ranked,\n",
        "            previous_fixed_numsec=previous_fixed_numsec,\n",
        "            previous_parent_numsec=previous_parent_numsec,\n",
        "            parent_numsec=parent_numsec,\n",
        "        )\n",
        "\n",
        "    # Selection should use only positive momentum securities\n",
        "    ranked_positive = ranked[ranked[\"Final Z Score\"] > 0].copy()\n",
        "\n",
        "    selected = apply_buffer_rules(\n",
        "        ranked_positive,\n",
        "        previous_holdings,\n",
        "        fixed_numsec,\n",
        "    )\n",
        "\n",
        "    selected = calculate_weights(selected)\n",
        "\n",
        "    selected = apply_issuer_weight_cap(\n",
        "        selected,\n",
        "        parent_weights=parent_weights,\n",
        "        issuer_col=\"Issuer\" if \"Issuer\" in selected.columns else None,\n",
        "    )\n",
        "\n",
        "    return selected, fixed_numsec"
      ],
      "id": "LSiibPXRiJy8"
    },
