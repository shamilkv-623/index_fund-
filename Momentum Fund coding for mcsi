        "def create_empty_corporate_events_template(\n",
        "    output_path: Optional[Union[str, Path]] = None,\n",
        ") -> pd.DataFrame:\n",
        "    template = pd.DataFrame(columns=DEFAULT_EVENT_COLUMNS)\n",
        "\n",
        "    if output_path is not None:\n",
        "        template.to_csv(output_path, index=False)\n",
        "        print(f\"Saved empty corporate events template: {output_path}\")\n",
        "\n",
        "    return template\n",
        "\n",
        "\n",
        "def normalize_corporate_events(events: pd.DataFrame) -> pd.DataFrame:\n",
        "    if events is None or events.empty:\n",
        "        return pd.DataFrame(columns=DEFAULT_EVENT_COLUMNS)\n",
        "\n",
        "    events = normalize_column_names(events)\n",
        "\n",
        "    for col in DEFAULT_EVENT_COLUMNS:\n",
        "        if col not in events.columns:\n",
        "            if col in [\"is_parent_deletion\", \"is_parent_addition\"]:\n",
        "                events[col] = False\n",
        "            elif col == \"vwf_factor\":\n",
        "                events[col] = 1.0\n",
        "            elif col in [\"cash_ratio\", \"stock_ratio\", \"spin_weight\"]:\n",
        "                events[col] = np.nan\n",
        "            else:\n",
        "                events[col] = \"\"\n",
        "\n",
        "    events[\"event_date\"] = pd.to_datetime(events[\"event_date\"], errors=\"coerce\")\n",
        "    events[\"event_type\"] = events[\"event_type\"].astype(str).str.upper().str.strip()\n",
        "    events[\"ticker\"] = events[\"ticker\"].astype(str).str.upper().str.strip()\n",
        "    events[\"new_ticker\"] = events[\"new_ticker\"].astype(str).str.upper().str.strip().replace(\"NAN\", \"\")\n",
        "    events[\"acquirer_ticker\"] = events[\"acquirer_ticker\"].astype(str).str.upper().str.strip().replace(\"NAN\", \"\")\n",
        "\n",
        "    for col in [\"cash_ratio\", \"stock_ratio\", \"spin_weight\", \"vwf_factor\"]:\n",
        "        events[col] = pd.to_numeric(events[col], errors=\"coerce\")\n",
        "\n",
        "    events[\"is_parent_deletion\"] = events[\"is_parent_deletion\"].fillna(False).astype(bool)\n",
        "    events[\"is_parent_addition\"] = events[\"is_parent_addition\"].fillna(False).astype(bool)\n",
        "\n",
        "    events = events.dropna(subset=[\"event_date\", \"ticker\"])\n",
        "    return events[DEFAULT_EVENT_COLUMNS].sort_values(\"event_date\").reset_index(drop=True)\n",
        "\n",
        "\n",
        "def load_corporate_events(path: Union[str, Path] = \"corporate_events.csv\") -> pd.DataFrame:\n",
        "    try:\n",
        "        events = pd.read_csv(path)\n",
        "    except FileNotFoundError:\n",
        "        print(f\"Corporate events file not found: {path}. Continuing with no events.\")\n",
        "        return pd.DataFrame(columns=DEFAULT_EVENT_COLUMNS)\n",
        "\n",
        "    return normalize_corporate_events(events)\n",
        "\n",
        "\n",
        "def ensure_portfolio_columns(portfolio: pd.DataFrame) -> pd.DataFrame:\n",
        "    portfolio = portfolio.copy()\n",
        "\n",
        "    if \"Final Weight\" not in portfolio.columns:\n",
        "        raise ValueError(\"Portfolio must contain a 'Final Weight' column.\")\n",
        "\n",
        "    if \"VWF\" not in portfolio.columns:\n",
        "        portfolio[\"VWF\"] = 1.0\n",
        "\n",
        "    if \"Momentum Score\" not in portfolio.columns:\n",
        "        portfolio[\"Momentum Score\"] = np.nan\n",
        "\n",
        "    return portfolio\n",
        "\n",
        "\n",
        "def apply_vwf_adjustment(\n",
        "    portfolio: pd.DataFrame,\n",
        "    ticker: str,\n",
        "    vwf_factor: Optional[float],\n",
        ") -> pd.DataFrame:\n",
        "    portfolio = portfolio.copy()\n",
        "\n",
        "    if ticker not in portfolio.index:\n",
        "        return portfolio\n",
        "\n",
        "    if pd.isna(vwf_factor):\n",
        "        return portfolio\n",
        "\n",
        "    portfolio.loc[ticker, \"VWF\"] = float(portfolio.loc[ticker, \"VWF\"]) * float(vwf_factor)\n",
        "    return portfolio\n",
        "\n",
        "\n",
        "def redistribute_cash_proceeds(\n",
        "    portfolio: pd.DataFrame,\n",
        "    cash_weight: float,\n",
        "    weight_col: str = \"Final Weight\",\n",
        ") -> pd.DataFrame:\n",
        "    portfolio = portfolio.copy()\n",
        "\n",
        "    if portfolio.empty or cash_weight <= 0:\n",
        "        return portfolio\n",
        "\n",
        "    existing_sum = portfolio[weight_col].sum()\n",
        "    if existing_sum <= 0:\n",
        "        return portfolio\n",
        "\n",
        "    portfolio[weight_col] = portfolio[weight_col] + (\n",
        "        portfolio[weight_col] / existing_sum\n",
        "    ) * cash_weight\n",
        "\n",
        "    return normalize_weights(portfolio, weight_col)\n",
        "\n",
        "\n",
        "def apply_corporate_events(\n",
        "    portfolio: pd.DataFrame,\n",
        "    events: pd.DataFrame,\n",
        "    start_date: Union[str, pd.Timestamp],\n",
        "    end_date: Union[str, pd.Timestamp],\n",
        "    weight_col: str = \"Final Weight\",\n",
        ") -> Tuple[pd.DataFrame, pd.DataFrame]:\n",
        "\n",
        "    if events.empty or portfolio.empty:\n",
        "        return portfolio.copy(), pd.DataFrame()\n",
        "\n",
        "    portfolio = ensure_portfolio_columns(portfolio)\n",
        "    start_date = pd.to_datetime(start_date)\n",
        "    end_date = pd.to_datetime(end_date)\n",
        "\n",
        "    period_events = events[\n",
        "        (events[\"event_date\"] > start_date) &\n",
        "        (events[\"event_date\"] <= end_date)\n",
        "    ].sort_values(\"event_date\")\n",
        "\n",
        "    event_log = []\n",
        "\n",
        "    for _, event in period_events.iterrows():\n",
        "        event_type = str(event.get(\"event_type\", \"\")).upper()\n",
        "        ticker = str(event.get(\"ticker\", \"\")).strip().upper()\n",
        "        event_date = event.get(\"event_date\")\n",
        "        vwf_factor = event.get(\"vwf_factor\", np.nan)\n",
        "\n",
        "        if not ticker:\n",
        "            continue\n",
        "\n",
        "        if bool(event.get(\"is_parent_addition\", False)) or event_type == \"NEW_ADDITION\":\n",
        "            event_log.append({\n",
        "                \"date\": event_date,\n",
        "                \"event\": event_type,\n",
        "                \"ticker\": ticker,\n",
        "                \"action\": \"Parent addition ignored until next scheduled review\",\n",
        "            })\n",
        "            continue\n",
        "\n",
        "        if bool(event.get(\"is_parent_deletion\", False)) or event_type == \"DELETE\":\n",
        "            if ticker in portfolio.index:\n",
        "                removed_weight = float(portfolio.loc[ticker, weight_col])\n",
        "                portfolio = portfolio.drop(index=ticker)\n",
        "                portfolio = redistribute_cash_proceeds(portfolio, removed_weight, weight_col)\n",
        "                event_log.append({\n",
        "                    \"date\": event_date,\n",
        "                    \"event\": event_type,\n",
        "                    \"ticker\": ticker,\n",
        "                    \"action\": \"Parent deletion reflected; weight redistributed pro-rata\",\n",
        "                })\n",
        "            continue\n",
        "\n",
        "        if event_type == \"SPINOFF\":\n",
        "            child = str(event.get(\"new_ticker\", \"\")).strip().upper()\n",
        "            spin_weight = event.get(\"spin_weight\", np.nan)\n",
        "            spin_weight = 0.0 if pd.isna(spin_weight) else float(spin_weight)\n",
        "\n",
        "            if ticker in portfolio.index and child and spin_weight > 0:\n",
        "                parent_weight = float(portfolio.loc[ticker, weight_col])\n",
        "                transfer_weight = parent_weight * spin_weight\n",
        "\n",
        "                portfolio.loc[ticker, weight_col] = parent_weight - transfer_weight\n",
        "\n",
        "                child_row = portfolio.loc[ticker].copy()\n",
        "                child_row[weight_col] = transfer_weight\n",
        "                child_row[\"VWF\"] = 1.0\n",
        "                portfolio.loc[child] = child_row\n",
        "\n",
        "                portfolio = apply_vwf_adjustment(portfolio, ticker, vwf_factor)\n",
        "                portfolio = normalize_weights(portfolio, weight_col)\n",
        "\n",
        "                action = f\"Spin-off child {child} added; parent weight reduced\"\n",
        "            else:\n",
        "                action = \"Spin-off skipped because parent/child/spin_weight data was incomplete\"\n",
        "\n",
        "            event_log.append({\n",
        "                \"date\": event_date,\n",
        "                \"event\": event_type,\n",
        "                \"ticker\": ticker,\n",
        "                \"action\": action,\n",
        "            })\n",
        "            continue\n",
        "\n",
        "        if event_type in [\"MERGER_CASH\", \"MERGER_STOCK\", \"MERGER_MIXED\"]:\n",
        "            if ticker not in portfolio.index:\n",
        "                continue\n",
        "\n",
        "            target_weight = float(portfolio.loc[ticker, weight_col])  # HELP FOR THE REDISTRIBUTION OF THE MISSING TRGET WEIGHT\n",
        "            acquirer = str(event.get(\"acquirer_ticker\", \"\")).strip().upper()\n",
        "            cash_ratio = event.get(\"cash_ratio\", np.nan)\n",
        "            stock_ratio = event.get(\"stock_ratio\", np.nan)\n",
        "\n",
        "            cash_part = 0.0 if pd.isna(cash_ratio) else float(cash_ratio)\n",
        "            stock_part = (\n",
        "                1.0 if event_type == \"MERGER_STOCK\" and pd.isna(stock_ratio)\n",
        "                else 0.0 if pd.isna(stock_ratio)\n",
        "                else float(stock_ratio)\n",
        "            )\n",
        "#If the cash and stock parts add up to more than 100%, it rescales them:\n",
        "            total_part = cash_part + stock_part\n",
        "            if total_part > 1.0:\n",
        "                cash_part = cash_part / total_part\n",
        "                stock_part = stock_part / total_part\n",
        "\n",
        "            cash_weight = target_weight * cash_part\n",
        "            stock_weight = target_weight * stock_part\n",
        "            residual_weight = target_weight - cash_weight - stock_weight\n",
        "\n",
        "            portfolio = portfolio.drop(index=ticker)\n",
        "            action_parts = []\n",
        "\n",
        "            if stock_weight > 0 and acquirer and acquirer in portfolio.index:\n",
        "                portfolio.loc[acquirer, weight_col] += stock_weight\n",
        "                portfolio = apply_vwf_adjustment(portfolio, acquirer, vwf_factor)\n",
        "                action_parts.append(f\"stock consideration transferred to {acquirer}\")\n",
        "            elif stock_weight > 0:\n",
        "                cash_weight += stock_weight\n",
        "                action_parts.append(\"stock consideration redistributed because acquirer not in index\")\n",
        "\n",
        "            if cash_weight > 0 or residual_weight > 0:\n",
        "                portfolio = redistribute_cash_proceeds(portfolio, cash_weight + residual_weight, weight_col)\n",
        "                action_parts.append(\"cash/residual consideration redistributed pro-rata\")\n",
        "\n",
        "            portfolio = normalize_weights(portfolio, weight_col)\n",
        "\n",
        "            event_log.append({\n",
        "                \"date\": event_date,\n",
        "                \"event\": event_type,\n",
        "                \"ticker\": ticker,\n",
        "                \"action\": \"; \".join(action_parts) if action_parts else \"Merger applied\",\n",
        "            })\n",
        "            continue\n",
        "\n",
        "        if event_type == \"CHANGE_CHARACTERISTICS\": # This means the company stays in the portfolio, but some characteristic changes.\n",
        "            portfolio = apply_vwf_adjustment(portfolio, ticker, vwf_factor)\n",
        "            event_log.append({\n",
        "                \"date\": event_date,\n",
        "                \"event\": event_type,\n",
        "                \"ticker\": ticker,\n",
        "                \"action\": \"Security retained; VWF adjusted if factor supplied\",\n",
        "            })\n",
        "            continue\n",
        "\n",
        "        event_log.append({\n",
        "            \"date\": event_date,\n",
        "            \"event\": event_type,\n",
        "            \"ticker\": ticker,\n",
        "            \"action\": \"Unrecognized event type; no action taken\",\n",
        "        })\n",
        "\n",
        "    return normalize_weights(portfolio, weight_col), pd.DataFrame(event_log)"
      ],
