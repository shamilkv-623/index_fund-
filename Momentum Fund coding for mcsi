        "def build_strategy_returns(prices: pd.DataFrame, portfolio_history: Dict[str, pd.DataFrame]) -> pd.Series:\n",
        "    daily_returns = prices.pct_change().fillna(0)\n",
        "\n",
        "    strategy_returns = pd.Series(index=daily_returns.index, dtype=float)\n",
        "\n",
        "    rebalance_dates = sorted(pd.to_datetime(list(portfolio_history.keys())))\n",
        "\n",
        "    for i, reb_date in enumerate(rebalance_dates):\n",
        "        next_date = (\n",
        "            rebalance_dates[i + 1]\n",
        "            if i + 1 < len(rebalance_dates)\n",
        "            else daily_returns.index[-1]\n",
        "        )\n",
        "\n",
        "        portfolio = portfolio_history[str(reb_date.date())]\n",
        "        weights = portfolio[\"Final Weight\"]\n",
        "\n",
        "        period_returns = daily_returns.loc[\n",
        "            (daily_returns.index > reb_date) &\n",
        "            (daily_returns.index <= next_date),\n",
        "            weights.index,\n",
        "        ]\n",
        "\n",
        "        strategy_returns.loc[period_returns.index] = (\n",
        "            period_returns.mul(weights, axis=1).sum(axis=1)\n",
        "        )\n",
        "\n",
        "    return strategy_returns.dropna()\n",
        "\n",
        "\n",
        "def performance_summary(\n",
        "    strategy_returns: pd.Series,\n",
        "    benchmark_returns: Optional[pd.Series] = None,\n",
        "    rf: float = 0.065,\n",
        ") -> pd.Series:\n",
        "\n",
        "    trading_days = 250 # as mention in document\n",
        "    nav = (1 + strategy_returns).cumprod()\n",
        "\n",
        "    cagr = nav.iloc[-1] ** (trading_days / len(strategy_returns)) - 1\n",
        "    volatility = strategy_returns.std() * np.sqrt(trading_days)\n",
        "    sharpe = (cagr - rf) / volatility if volatility > 0 else np.nan\n",
        "    drawdown = nav / nav.cummax() - 1\n",
        "    max_drawdown = drawdown.min()\n",
        "\n",
        "    summary = {\n",
        "        \"CAGR\": cagr,\n",
        "        \"Volatility\": volatility,\n",
        "        \"Sharpe Ratio\": sharpe,\n",
        "        \"Max Drawdown\": max_drawdown,\n",
        "    }\n",
        "\n",
        "    if benchmark_returns is not None:\n",
        "        aligned = pd.concat([strategy_returns, benchmark_returns], axis=1).dropna()\n",
        "        aligned.columns = [\"Strategy\", \"Benchmark\"]\n",
        "\n",
        "        active_returns = aligned[\"Strategy\"] - aligned[\"Benchmark\"]\n",
        "        benchmark_nav = (1 + aligned[\"Benchmark\"]).cumprod()\n",
        "        benchmark_cagr = benchmark_nav.iloc[-1] ** (trading_days / len(aligned)) - 1\n",
        "        tracking_error = active_returns.std() * np.sqrt(trading_days)\n",
        "        excess_cagr = cagr - benchmark_cagr\n",
        "        information_ratio = excess_cagr / tracking_error if tracking_error > 0 else np.nan\n",
        "\n",
        "        summary.update({\n",
        "            \"Benchmark CAGR\": benchmark_cagr,\n",
        "            \"Excess CAGR\": excess_cagr,\n",
        "            \"Tracking Error\": tracking_error,\n",
        "            \"Information Ratio\": information_ratio,\n",
        "        })\n",
        "\n",
        "    return pd.Series(summary)\n",
        "\n",
        "\n",
        "strategy_returns = build_strategy_returns(\n",
        "    prices=prices,\n",
        "    portfolio_history=results[\"portfolio_history\"],\n",
        ")\n",
        "\n",
        "strategy_nav = (1 + strategy_returns).cumprod()\n",
        "\n",
        "\n",
        "# NIFTY 500 benchmark\n",
        "benchmark_ticker = \"^CRSLDX\"\n",
        "\n",
        "benchmark_prices = yf.download(\n",
        "    benchmark_ticker,\n",
        "    start=strategy_returns.index.min().strftime(\"%Y-%m-%d\"),\n",
        "    end=(strategy_returns.index.max() + pd.Timedelta(days=1)).strftime(\"%Y-%m-%d\"),\n",
        "    auto_adjust=True,\n",
        "    progress=False,\n",
        ")[\"Close\"]\n",
        "\n",
        "benchmark_returns = benchmark_prices.pct_change().dropna()\n",
        "\n",
        "benchmark_returns = benchmark_returns.reindex(\n",
        "    strategy_returns.index\n",
        ").ffill()\n",
        "\n",
        "benchmark_nav = (1 + benchmark_returns).cumprod()\n",
        "\n",
        "\n",
        "perf = performance_summary(\n",
        "    strategy_returns=strategy_returns,\n",
        "    benchmark_returns=benchmark_returns,\n",
        "    rf=0.065,\n",
        ")\n",
        "\n",
        "print(\"Performance Summary\")\n",
