      "source": [
        "# A slippage assumption of 5 basis points has been used, which is reasonable for highly liquid stocks, while actual slippage may be lower for very liquid securities and higher for relatively illiquid stocks."
      ],
      "metadata": {
        "id": "-Yrq-NdFo90J"
      },
      "id": "-Yrq-NdFo90J"
    },
    {
      "cell_type": "code",
      "source": [
        "ANNUAL_REBALANCES = 2  # semi-annual rebalance\n",
        "\n",
        "# Delivery transaction cost assumptions\n",
        "BROKERAGE_BPS = 0          # delivery brokerage\n",
        "STT_BPS = 10               # 0.1%\n",
        "EXCHANGE_TXN_BPS = 0.35    # approx 0.0035%\n",
        "SEBI_BPS = 0.01            # ₹10 per crore = 0.0001%\n",
        "STAMP_DUTY_BPS = 1.5       # 0.015%\n",
        "SLIPPAGE_BPS = 5           # assumed slippage\n",
        "GST_RATE = 0.18            # GST on brokerage + exchange + SEBI\n",
        "\n",
        "\n",
        "def calculate_turnover(portfolio_history):\n",
        "    rebalance_dates = sorted(pd.to_datetime(list(portfolio_history.keys())))\n",
        "    turnover_dict = {}\n",
        "\n",
        "    for i in range(1, len(rebalance_dates)):\n",
        "        prev_key = str(rebalance_dates[i - 1].date())\n",
        "        curr_key = str(rebalance_dates[i].date())\n",
        "\n",
        "        prev_weights = portfolio_history[prev_key][\"Final Weight\"]\n",
        "        curr_weights = portfolio_history[curr_key][\"Final Weight\"]\n",
        "\n",
        "        all_tickers = prev_weights.index.union(curr_weights.index)\n",
        "\n",
        "        prev_weights = prev_weights.reindex(all_tickers).fillna(0)\n",
        "        curr_weights = curr_weights.reindex(all_tickers).fillna(0)\n",
        "\n",
        "        turnover = np.abs(curr_weights - prev_weights).sum() / 2\n",
        "        turnover_dict[rebalance_dates[i]] = turnover\n",
        "\n",
        "    return pd.Series(turnover_dict)\n",
        "\n",
        "\n",
        "turnover_series = calculate_turnover(results[\"portfolio_history\"])\n",
        "\n",
        "brokerage_cost = turnover_series * (BROKERAGE_BPS / 10000)\n",
        "stt_cost = turnover_series * (STT_BPS / 10000)\n",
        "exchange_cost = turnover_series * (EXCHANGE_TXN_BPS / 10000)\n",
        "sebi_cost = turnover_series * (SEBI_BPS / 10000)\n",
        "stamp_duty_cost = turnover_series * (STAMP_DUTY_BPS / 10000)\n",
        "slippage_cost = turnover_series * (SLIPPAGE_BPS / 10000)\n",
        "\n",
        "gst_cost = GST_RATE * (\n",
        "    brokerage_cost\n",
        "    + exchange_cost\n",
        "    + sebi_cost\n",
        ")\n",
        "\n",
        "transaction_cost_series = (\n",
        "    brokerage_cost\n",
        "    + stt_cost\n",
        "    + exchange_cost\n",
        "    + sebi_cost\n",
        "    + stamp_duty_cost\n",
        "    + slippage_cost\n",
        "    + gst_cost\n",
        ")\n",
        "\n",
        "annual_turnover = turnover_series.mean() * ANNUAL_REBALANCES\n",
        "\n",
        "strategy_returns_net = strategy_returns.copy()\n",
        "\n",
        "for cost_date, cost in transaction_cost_series.items():\n",
        "    valid_dates = strategy_returns_net.index[strategy_returns_net.index >= cost_date]\n",
        "\n",
        "    if len(valid_dates) > 0:\n",
        "        actual_cost_date = valid_dates[0]\n",
        "        strategy_returns_net.loc[actual_cost_date] -= cost\n",
        "\n",
        "\n",
        "print(\"Average Annual Turnover:\", f\"{annual_turnover:.2%}\")\n",
        "print(\"Average Transaction Cost per Rebalance:\", f\"{transaction_cost_series.mean():.4%}\")\n",
        "print(\"Brokerage:\", f\"{BROKERAGE_BPS} bps\")\n",
        "print(\"STT:\", f\"{STT_BPS} bps\")\n",
        "print(\"Exchange Transaction Charge:\", f\"{EXCHANGE_TXN_BPS} bps\")\n",
        "print(\"SEBI Turnover Fee:\", f\"{SEBI_BPS} bps\")\n",
        "print(\"Stamp Duty:\", f\"{STAMP_DUTY_BPS} bps\")\n",
        "print(\"Slippage:\", f\"{SLIPPAGE_BPS} bps\")\n",
        "print(\"GST:\", f\"{GST_RATE:.0%} on brokerage + exchange + SEBI\")\n",
        "\n",
        "\n",
        "strategy_nav_gross = (1 + strategy_returns).cumprod()\n",
        "strategy_nav_net = (1 + strategy_returns_net).cumprod()\n",
        "\n",
        "nav_cost_comparison = pd.DataFrame({\n",
        "    \"Gross Strategy\": strategy_nav_gross,\n",
        "    \"Net Strategy After Costs\": strategy_nav_net,\n",
        "}).dropna()\n",
        "\n",
        "nav_cost_comparison.plot(\n",
        "    figsize=(12, 6),\n",
        "    title=\"Gross vs Net Strategy NAV After Delivery Transaction Costs + Slippage\"\n",
        ")\n",
        "\n",
        "plt.ylabel(\"NAV\")\n",
        "plt.xlabel(\"Date\")\n",
        "plt.show()"
