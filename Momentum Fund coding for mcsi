        "def get_risk_free_rate_for_ticker(\n",
        "    ticker: str,\n",
        "    rebalance_date: Union[str, pd.Timestamp],\n",
        "    ticker_country_map: Optional[Dict[str, str]] = None,\n",
        "    country_rf_rates: Optional[Union[pd.DataFrame, pd.Series, Dict[str, float]]] = None,\n",
        "    default_rate: float = 0.0,\n",
        ") -> float:\n",
        "\n",
        "    if country_rf_rates is None:\n",
        "        return float(default_rate)\n",
        "\n",
        "    country = None\n",
        "    if ticker_country_map:\n",
        "        country = ticker_country_map.get(ticker, ticker_country_map.get(str(ticker).upper()))\n",
        "\n",
        "    if isinstance(country_rf_rates, dict):\n",
        "        if country and country in country_rf_rates:\n",
        "            return float(country_rf_rates[country])\n",
        "        return float(default_rate)\n",
        "\n",
        "    rebalance_date = pd.to_datetime(rebalance_date)\n",
        "\n",
        "    if isinstance(country_rf_rates, pd.Series):\n",
        "        series = country_rf_rates.sort_index().loc[:rebalance_date]   # This avoids look-ahead bias.\n",
        "        return float(series.iloc[-1]) if not series.empty else float(default_rate)\n",
        "\n",
        "    if isinstance(country_rf_rates, pd.DataFrame):\n",
        "        if country is None or country not in country_rf_rates.columns:\n",
        "            return float(default_rate)\n",
        "\n",
        "        series = country_rf_rates[country].dropna().sort_index().loc[:rebalance_date]\n",
        "        return float(series.iloc[-1]) if not series.empty else float(default_rate)\n",
        "\n",
        "    return float(default_rate)\n",
        "\n",
        "\n",
        "def get_risk_free_rates_for_universe(\n",
        "    tickers: Iterable[str],\n",
        "    rebalance_date: Union[str, pd.Timestamp],\n",
        "    ticker_country_map: Optional[Dict[str, str]] = None,\n",
        "    country_rf_rates: Optional[Union[pd.DataFrame, pd.Series, Dict[str, float]]] = None,\n",
        "    default_rate: float = 0.0,\n",
        ") -> pd.Series:\n",
        "\n",
        "    return pd.Series({\n",
        "        ticker: get_risk_free_rate_for_ticker(\n",
        "            ticker=ticker,\n",
        "            rebalance_date=rebalance_date,\n",
        "            ticker_country_map=ticker_country_map,\n",
        "            country_rf_rates=country_rf_rates,\n",
        "            default_rate=default_rate,\n",
        "        )\n",
        "        for ticker in tickers\n",
        "    })"
      ],
