        "  def calculate_momentum_scores(\n",
        "      prices_slice: pd.DataFrame,\n",
        "      rebalance_date: Union[str, pd.Timestamp],\n",
        "      ticker_country_map: Optional[Dict[str, str]] = None,\n",
        "      country_rf_rates: Optional[Union[pd.DataFrame, pd.Series, Dict[str, float]]] = None,\n",
        "      default_risk_free_rate: float = 0.0,\n",
        "  ) -> pd.DataFrame:\n",
        "\n",
        "      rebalance_date = pd.to_datetime(rebalance_date)\n",
        "      prices_slice = prices_slice.loc[:rebalance_date].copy()  # This avoids look-ahead bias.\n",
        "\n",
        "      monthly_prices = prices_slice.resample(\"ME\").last()\n",
        "      weekly_prices = prices_slice.resample(\"W-FRI\").last()\n",
        "\n",
        "      if len(monthly_prices) < 8 or len(weekly_prices) < 156:\n",
        "          return pd.DataFrame()\n",
        "\n",
        "      p_t_1 = monthly_prices.iloc[-2]\n",
        "      p_t_7 = monthly_prices.iloc[-8]\n",
        "\n",
        "      rf = get_risk_free_rates_for_universe(\n",
        "          prices_slice.columns,\n",
        "          rebalance_date,\n",
        "          ticker_country_map=ticker_country_map,\n",
        "          country_rf_rates=country_rf_rates,\n",
        "          default_rate=default_risk_free_rate,\n",
        "      )\n",
        "\n",
        "  # Assumption: the annualized risk-free rate is scaled to match the momentum horizon.\n",
        "      six_month_momentum = (p_t_1 / p_t_7 - 1) - (rf * 6 / 12)\n",
        "\n",
        "      twelve_month_momentum = pd.Series(index=prices_slice.columns, dtype=float)\n",
        "      if len(monthly_prices) >= 14:\n",
        "          p_t_13 = monthly_prices.iloc[-14]\n",
        "          twelve_month_momentum = (p_t_1 / p_t_13 - 1) - rf\n",
        "\n",
        "      weekly_returns = weekly_prices.pct_change()\n",
        "      volatility_3y = weekly_returns.tail(156).std() * np.sqrt(52)\n",
        "      volatility_3y = volatility_3y.replace(0, np.nan)\n",
        "\n",
        "      risk_adj_6m = six_month_momentum / volatility_3y\n",
        "      risk_adj_12m = twelve_month_momentum / volatility_3y\n",
        "\n",
        "      z_6m = (risk_adj_6m - risk_adj_6m.mean()) / risk_adj_6m.std()\n",
        "      z_12m = (risk_adj_12m - risk_adj_12m.mean()) / risk_adj_12m.std()\n",
        "\n",
        "      combined_df = pd.concat([z_6m, z_12m], axis=1)\n",
        "      combined_df.columns = [\"6M Z Score\", \"12M Z Score\"]\n",
        "\n",
        "      combined = combined_df.mean(axis=1, skipna=True)\n",
        "      combined = combined.replace([np.inf, -np.inf], np.nan).dropna()\n",
        "\n",
        "      final_z = (combined - combined.mean()) / combined.std()\n",
        "      winsorized_z = final_z.clip(lower=-3, upper=3)\n",
        "      momentum_score = winsorized_z.apply(lambda z: 1 + z if z > 0 else 1 / (1 - z))\n",
        "\n",
        "      result = pd.DataFrame({\n",
        "          \"6M Momentum\": six_month_momentum,\n",
        "          \"12M Momentum\": twelve_month_momentum,\n",
        "          \"3Y Volatility\": volatility_3y,\n",
        "          \"Risk Adjusted 6M\": risk_adj_6m,\n",
        "          \"Risk Adjusted 12M\": risk_adj_12m,\n",
        "          \"6M Z Score\": z_6m,\n",
        "          \"12M Z Score\": z_12m,\n",
        "          \"Combined Score\": combined,\n",
        "          \"Final Z Score\": final_z,\n",
        "          \"Winsorized Z Score\": winsorized_z,\n",
        "          \"Momentum Score\": momentum_score,\n",
        "      })\n",
        "\n",
        "      return result.dropna(subset=[\"6M Momentum\", \"3Y Volatility\", \"Momentum Score\"])\n",
        "\n",
        "\n",
