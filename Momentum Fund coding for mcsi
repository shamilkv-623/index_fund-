        "      final_z = (risk_adj_6m - risk_adj_6m.mean()) / risk_adj_6m.std()\n",
        "      winsorized_z = final_z.clip(lower=-3, upper=3) # to remove the outliar\n",
        "      momentum_score = winsorized_z.apply(lambda z: 1 + z if z > 0 else 1 / (1 - z)) # On page 5, MSCI defines the Momentum Score as\n",
        "\n",
        "\n",
        "\n",
        "      result = pd.DataFrame({\n",
        "          \"6M Momentum\": six_month_momentum,\n",
        "          \"3Y Volatility\": volatility_3y,\n",
        "          \"Risk Adjusted 6M\": risk_adj_6m,\n",
        "          \"Final Z Score\": final_z,\n",
        "          \"Winsorized Z Score\": winsorized_z,\n",
        "          \"Momentum Score\": momentum_score,\n",
        "      })\n",
        "\n",
        "      return result.dropna()"
