        "def polite_delay(min_sec: float = 1.5, max_sec: float = 4.0) -> None:\n",
        "    time.sleep(random.uniform(min_sec, max_sec))\n",
        "\n",
        "\n",
        "def normalize_column_names(df: pd.DataFrame) -> pd.DataFrame:\n",
        "    df = df.copy()\n",
        "    df.columns = [\n",
        "        str(col).strip().replace(\"\\n\", \" \").replace(\"\\t\", \" \")\n",
        "        for col in df.columns\n",
        "    ]\n",
        "    return df\n",
        "\n",
        "\n",
        "def safe_to_datetime(value) -> pd.Timestamp:\n",
        "    return pd.to_datetime(value, errors=\"coerce\")\n",
        "\n",
        "\n",
        "def normalize_weights(portfolio: pd.DataFrame, weight_col: str = \"Final Weight\") -> pd.DataFrame:\n",
        "    portfolio = portfolio.copy()\n",
        "    if portfolio.empty or weight_col not in portfolio.columns:\n",
        "        return portfolio\n",
        "\n",
        "    total_weight = portfolio[weight_col].sum()\n",
        "    if total_weight > 0:\n",
        "        portfolio[weight_col] = portfolio[weight_col] / total_weight\n",
        "\n",
        "    return portfolio\n",
        "\n",
        "\n",
        "def get_business_day_offset(\n",
        "    date: Union[str, pd.Timestamp],\n",
        "    offset: int,\n",
        "    calendar: str = \"XBOM\"\n",
        ") -> pd.Timestamp:\n",
        "    date = pd.to_datetime(date).normalize()\n",
        "\n",
        "    if MARKET_CALENDARS_AVAILABLE:\n",
        "        cal = mcal.get_calendar(calendar)\n",
        "        start = date - pd.Timedelta(days=60)\n",
        "        end = date + pd.Timedelta(days=5)\n",
        "        schedule = cal.schedule(start_date=start, end_date=end)\n",
        "        sessions = pd.DatetimeIndex(schedule.index).tz_localize(None).normalize()\n",
        "        sessions = sessions[sessions <= date]\n",
        "\n",
        "        if len(sessions) < abs(offset) + 1:\n",
        "            raise ValueError(\"Not enough business sessions to compute offset.\")\n",
        "\n",
        "        return sessions[offset]\n",
        "\n",
        "    return (date + pd.offsets.BDay(offset)).normalize()\n",
        "\n",
        "\n",
        "def get_month_end_dates(\n",
        "    start: Union[str, pd.Timestamp],\n",
        "    end: Union[str, pd.Timestamp],\n",
        ") -> pd.DatetimeIndex:\n",
        "    start = pd.to_datetime(start)\n",
        "    end = pd.to_datetime(end)\n",
        "    return pd.date_range(start=start, end=end, freq=\"ME\")"
      ],
