        "def round_up_numsec(numsec: float) -> int:\n",
        "    if pd.isna(numsec) or numsec <= 0:\n",
        "        return 0\n",
        "\n",
        "    if numsec < 100:\n",
        "        base = 10\n",
        "    elif numsec < 300:\n",
        "        base = 25\n",
        "    else:\n",
        "        base = 50\n",
        "\n",
        "    return int(np.ceil(numsec / base) * base) # Upward rounding off\n",
        "\n",
        "# This function decides the fixed number of securities to include when the MSCI Momentum Index is being built for the first time.\n",
        "\n",
        "def determine_fixed_numsec_initial(\n",
        "    ranked_universe: pd.DataFrame,\n",
        "    parent_numsec: int, #parent number of securities\n",
        "    parent_weight_col: str = \"Parent Weight\",\n",
        "    z_col: str = \"Final Z Score\",\n",
        "    target_mcap_coverage: float = 0.30,\n",
        "    min_parent_numsec_pct: float = 0.10,\n",
        "    max_numsec_coverage: float = 0.40,\n",
        "    min_mcap_coverage_if_adjusted: float = 0.20,\n",
        ") -> int:\n",
        "\n",
        "    if ranked_universe.empty or parent_numsec <= 0:\n",
        "        return 0\n",
        "\n",
        "    df = ranked_universe.copy()\n",
        "    df = df[df[z_col] > 0].sort_values(\n",
        "        [z_col, parent_weight_col],\n",
        "        ascending=[False, False]\n",
        "    )\n",
        "\n",
        "    proforma_parent_numsec = len(df)\n",
        "\n",
        "    if proforma_parent_numsec == 0: # this will only take the positive momentum stock only\n",
        "        return 0\n",
        "\n",
        "    # If positive momentum universe <= 25, select all securities\n",
        "    if proforma_parent_numsec <= 25:\n",
        "        return proforma_parent_numsec\n",
        "\n",
        "    df[\"cum_parent_weight\"] = df[parent_weight_col].fillna(0).cumsum()\n",
        "\n",
        "    # NumSec required to reach 30% parent mcap coverage\n",
        "    n_for_30 = int((df[\"cum_parent_weight\"] < target_mcap_coverage).sum() + 1)\n",
        "    n_for_30 = min(n_for_30, proforma_parent_numsec) # for preventing from the edge case\n",
        "\n",
        "\n",
        "    if n_for_30 <= 25:\n",
        "        fixed_numsec = 25\n",
        "    elif n_for_30 <= min_parent_numsec_pct * parent_numsec:\n",
        "        fixed_numsec = round_up_numsec(min_parent_numsec_pct * parent_numsec)\n",
        "    else:\n",
        "        fixed_numsec = round_up_numsec(n_for_30)\n",
        "\n",
        "    fixed_numsec = min(fixed_numsec, proforma_parent_numsec)\n",
        "\n",
        "    # If NumSec coverage exceeds 40%, reduce until <= 40%\n",
        "    if fixed_numsec / parent_numsec > max_numsec_coverage:\n",
        "        fixed_numsec = int(np.floor(max_numsec_coverage * parent_numsec))\n",
        "        fixed_numsec = max(1, min(fixed_numsec, proforma_parent_numsec))\n",
        "\n",
        "        # If Mcap coverage < 20%, increase NumSec until either:\n",
        "        # Mcap coverage >= 20% OR NumSec coverage > 40%\n",
        "        while fixed_numsec < proforma_parent_numsec:\n",
        "            mcap_coverage = df.head(fixed_numsec)[parent_weight_col].sum()\n",
        "\n",
        "            if mcap_coverage >= min_mcap_coverage_if_adjusted:\n",
        "                break\n",
        "\n",
        "            next_numsec = fixed_numsec + 1\n",
        "\n",
        "            if next_numsec / parent_numsec > max_numsec_coverage:\n",
        "                break\n",
        "\n",
        "            fixed_numsec = next_numsec\n",
        "\n",
        "        fixed_numsec = round_up_numsec(fixed_numsec)\n",
        "        fixed_numsec = min(fixed_numsec, proforma_parent_numsec)\n",
        "\n",
        "    return int(fixed_numsec)\n",
        "\n",
        "# Instead of recalculating the index size every time, it tries to preserve the previous size.\n",
        "# Main idea is Keep the same number of securities as last , rebalance unless something unusual happens.\n",
        "\n",
        "def determine_fixed_numsec_ongoing(\n",
        "    ranked_universe: pd.DataFrame,\n",
        "    previous_fixed_numsec: int,\n",
        "    previous_parent_numsec: int,\n",
        "    parent_numsec: int, # this can lead to change as the number of stock in the index can be changed\n",
        "    parent_weight_col: str = \"Parent Weight\",\n",
        "    z_col: str = \"Final Z Score\",\n",
        ") -> int:\n",
        "\n",
        "    if ranked_universe.empty or parent_numsec <= 0:\n",
        "        return 0\n",
        "\n",
        "    df_pos = ranked_universe[ranked_universe[z_col] > 0].copy()\n",
        "    proforma_parent_numsec = len(df_pos)\n",
        "\n",
        "    if proforma_parent_numsec == 0:\n",
        "        return 0\n",
        "\n",
        "    # 1. If previous fixed NumSec > current proforma parent NumSec,\n",
        "    # apply initial construction box algorithm\n",
        "    if previous_fixed_numsec > proforma_parent_numsec:\n",
        "        return determine_fixed_numsec_initial(\n",
        "            ranked_universe=ranked_universe,\n",
        "            parent_numsec=parent_numsec,\n",
        "            parent_weight_col=parent_weight_col,\n",
        "            z_col=z_col,\n",
        "        )\n",
        "\n",
        "    # 2. If current proforma parent NumSec <= 25, select all securities\n",
        "    if proforma_parent_numsec <= 25:\n",
        "        return proforma_parent_numsec\n",
        "\n",
        "    # 3. If parent NumSec in previous rebalancing < 25,\n",
        "    # apply initial construction box algorithm\n",
        "    # If the previous rebalance was based on a very small parent universe (<25 stocks), don't trust the previous portfolio structure; rebuild the portfolio from scratch.\n",
        "    if previous_parent_numsec < 25:\n",
        "        return determine_fixed_numsec_initial(\n",
        "            ranked_universe=ranked_universe,\n",
        "            parent_numsec=parent_numsec,\n",
        "            parent_weight_col=parent_weight_col,\n",
        "            z_col=z_col,\n",
        "        )\n",
        "\n",
        "    # 4. If Mcap coverage using previous rebalance NumSec < 10%,\n",
        "    # apply initial construction box algorithm\n",
        "    df_pos = df_pos.sort_values(\n",
        "        [z_col, parent_weight_col],\n",
        "        ascending=[False, False]\n",
        "    )\n",
        "\n",
        "    current_mcap_coverage = (\n",
        "        df_pos.head(previous_fixed_numsec)[parent_weight_col]\n",
        "        .fillna(0)\n",
        "        .sum()\n",
        "    )\n",
        "\n",
        "    if current_mcap_coverage < 0.10:\n",
        "        return determine_fixed_numsec_initial(\n",
        "            ranked_universe=ranked_universe,\n",
        "            parent_numsec=parent_numsec,\n",
        "            parent_weight_col=parent_weight_col,\n",
        "            z_col=z_col,\n",
        "        ) # the current parent weight will be the rebalnce weight right not the previous one correct\n",
        "\n",
        "    return int(previous_fixed_numsec)\n",
        "\n",
        "\n",
        "def apply_buffer_rules(\n",
        "    ranked_universe: pd.DataFrame,\n",
        "    previous_holdings: Iterable[str],\n",
        "    fixed_numsec: int,\n",
        "    rank_col: str = \"Momentum Rank\",\n",
        ") -> pd.DataFrame:\n",
        "\n",
        "# Old stocks inside the buffer are protected from being removed,\n",
        "# while new stocks inside the buffer are not automatically added; they enter only when a portfolio slot becomes available.\n",
        "    if fixed_numsec <= 0 or ranked_universe.empty:\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    df = ranked_universe.copy().sort_values(rank_col)\n",
        "    previous_holdings = set(previous_holdings or [])\n",
        "\n",
        "    priority_cutoff = max(int(np.floor(0.5 * fixed_numsec)), 1)\n",
        "    buffer_upper = fixed_numsec + priority_cutoff\n",
        "\n",
        "    selected_indices = []\n",
        "\n",
        "    priority = df[df[rank_col] <= priority_cutoff].index.tolist()\n",
        "    selected_indices.extend(priority)\n",
        "\n",
        "    buffer_existing = df[\n",
        "        (df[rank_col] > priority_cutoff) &\n",
        "        (df[rank_col] <= buffer_upper) &\n",
        "        (df.index.isin(previous_holdings))\n",
        "    ].index.tolist()\n",
        "\n",
        "    for ticker in buffer_existing:\n",
        "        if ticker not in selected_indices and len(selected_indices) < fixed_numsec:\n",
        "            selected_indices.append(ticker)\n",
        "\n",
        "    for ticker in df.index:\n",
        "        if ticker not in selected_indices and len(selected_indices) < fixed_numsec:\n",
        "            selected_indices.append(ticker)\n",
        "\n",
        "    return df.loc[selected_indices]\n",
        "\n",
        "\n",
        "def calculate_weights(\n",
        "    selected: pd.DataFrame,\n",
        "    parent_weight_col: str = \"Parent Weight\",\n",
        "    momentum_score_col: str = \"Momentum Score\",\n",
        ") -> pd.DataFrame:\n",
        "\n",
        "# Take the selected stocks and assign portfolio weights based on both their parent weight and momentum score.\n",
        "\n",
        "    selected = selected.copy()\n",
        "    selected[\"Raw Momentum Weight\"] = selected[parent_weight_col] * selected[momentum_score_col]\n",
        "\n",
        "    total = selected[\"Raw Momentum Weight\"].sum()\n",
        "    selected[\"Final Weight\"] = (\n",
        "        np.nan if total <= 0 else selected[\"Raw Momentum Weight\"] / total\n",
        "    )\n",
        "\n",
        "    if \"VWF\" not in selected.columns: # it is for the variable weight factor\n",
        "        selected[\"VWF\"] = 1.0\n",
        "\n",
        "    return selected\n",
        "\n",
        "\n",
        "def get_issuer_cap(\n",
        "    parent_weights: pd.Series,\n",
        "    broad_index_cap: float = 0.05,\n",
        "    narrow_threshold: float = 0.10,\n",
        ") -> float:\n",
        "\n",
        "    max_parent_weight = float(parent_weights.max()) if len(parent_weights) else broad_index_cap\n",
        "\n",
        "    if max_parent_weight > narrow_threshold:\n",
        "        return max_parent_weight\n",
        "\n",
        "    return broad_index_cap\n",
        "\n",
        "\n",
        "def apply_issuer_weight_cap(\n",
        "    portfolio: pd.DataFrame,\n",
        "    parent_weights: Optional[pd.Series] = None,\n",
        "    issuer_col: Optional[str] = None,\n",
        "    weight_col: str = \"Final Weight\",\n",
        "    cap: Optional[float] = None,\n",
        "    max_iterations: int = 100,\n",
        ") -> pd.DataFrame:\n",
        "\n",
        "    portfolio = portfolio.copy()\n",
        "\n",
        "    if portfolio.empty:\n",
        "        return portfolio\n",
        "\n",
        "    if cap is None:\n",
        "        cap = 0.05 if parent_weights is None else get_issuer_cap(parent_weights)\n",
        "\n",
        "    if issuer_col is None or issuer_col not in portfolio.columns:\n",
        "        portfolio[\"_issuer_tmp\"] = portfolio.index.astype(str) # here we are creating the temporary issue , it is look like an fall back mechanism\n",
        "        issuer_col = \"_issuer_tmp\"\n",
        "\n",
        "    portfolio = normalize_weights(portfolio, weight_col)\n",
        "\n",
        "    for _ in range(max_iterations):\n",
        "        issuer_weights = portfolio.groupby(issuer_col)[weight_col].sum()\n",
        "        over_issuers = issuer_weights[issuer_weights > cap]\n",
        "\n",
        "        if over_issuers.empty:\n",
        "            break\n",
        "\n",
        "        excess_total = 0.0\n",
        "\n",
        "        # It cuts issuers above the cap, collects the removed weight, gives it to issuers below the cap, and repeats until no issuer is above the cap.\n",
        "\n",
        "        for issuer, issuer_weight in over_issuers.items():\n",
        "            rows = portfolio[portfolio[issuer_col] == issuer].index\n",
        "            scale = cap / issuer_weight\n",
        "            old_weights = portfolio.loc[rows, weight_col].copy()\n",
        "            portfolio.loc[rows, weight_col] = old_weights * scale\n",
        "            excess_total += float(old_weights.sum() - portfolio.loc[rows, weight_col].sum())\n",
        "\n",
        "        issuer_weights = portfolio.groupby(issuer_col)[weight_col].sum()\n",
        "        eligible_issuers = issuer_weights[issuer_weights < cap].index\n",
        "        eligible_rows = portfolio[portfolio[issuer_col].isin(eligible_issuers)].index\n",
        "        eligible_weight = portfolio.loc[eligible_rows, weight_col].sum()\n",
        "\n",
        "        if excess_total <= 0 or eligible_weight <= 0:\n",
        "            break\n",
        "\n",
        "        portfolio.loc[eligible_rows, weight_col] += (\n",
        "            portfolio.loc[eligible_rows, weight_col] / eligible_weight\n",
        "        ) * excess_total\n",
        "\n",
        "    portfolio = normalize_weights(portfolio, weight_col)\n",
        "\n",
        "    if \"_issuer_tmp\" in portfolio.columns:\n",
        "        portfolio = portfolio.drop(columns=[\"_issuer_tmp\"])\n",
        "\n",
        "    return portfolio"
