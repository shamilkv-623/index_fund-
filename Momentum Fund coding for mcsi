        "def run_msci_style_momentum_backtest(\n",
        "    prices: pd.DataFrame,\n",
        "    parent_weights_by_date: Dict[pd.Timestamp, pd.Series],\n",
        "    start_date: Union[str, pd.Timestamp],\n",
        "    end_date: Union[str, pd.Timestamp],\n",
        "    events_path: Optional[Union[str, Path]] = \"corporate_events.csv\",\n",
        "    corporate_events: Optional[pd.DataFrame] = None,\n",
        "    parent_index_ticker: str = \"^CRSLDX\",\n",
        "    ticker_country_map: Optional[Dict[str, str]] = None,\n",
        "    country_rf_rates: Optional[Union[pd.DataFrame, pd.Series, Dict[str, float]]] = None,\n",
        "    default_risk_free_rate: float = 0.0, # This is an fall back mechanism , when the country is missing in map, or not able to capture the country_rf_rate\n",
        "    issuer_map: Optional[Dict[str, str]] = None,\n",
        "    calendar: str = \"XBOM\"\n",
        ") -> Dict[str, object]:\n",
        "\n",
        "    start_date = pd.to_datetime(start_date)\n",
        "    end_date = pd.to_datetime(end_date)\n",
        "\n",
        "    if corporate_events is not None:\n",
        "        events = normalize_corporate_events(corporate_events)\n",
        "    elif events_path is not None:\n",
        "        events = load_corporate_events(events_path)\n",
        "    else:\n",
        "        events = pd.DataFrame(columns=DEFAULT_EVENT_COLUMNS)\n",
        "\n",
        "    parent_prices = download_parent_index_prices(\n",
        "        ticker=parent_index_ticker,\n",
        "        start=(start_date - pd.DateOffset(years=5)).strftime(\"%Y-%m-%d\"),\n",
        "        end=(end_date + pd.DateOffset(days=5)).strftime(\"%Y-%m-%d\"),\n",
        "    )\n",
        "\n",
        "    adhoc_dates, vol_trigger_table, adhoc_threshold = get_adhoc_rebalance_dates(\n",
        "        parent_prices,\n",
        "        threshold_percentile=0.95,\n",
        "        calendar=calendar,\n",
        "    )\n",
        "\n",
        "    scheduled_dates = get_scheduled_rebalance_dates(start_date, end_date, calendar=calendar)\n",
        "\n",
        "    all_rebalance_dates = [\n",
        "        d for d in get_all_rebalance_dates(scheduled_dates, adhoc_dates)\n",
        "        if start_date <= d <= end_date\n",
        "    ]\n",
        "\n",
        "    previous_date = None\n",
        "    previous_holdings = []\n",
        "    previous_fixed_numsec = None\n",
        "    previous_parent_numsec = None\n",
        "    current_portfolio = pd.DataFrame()\n",
        "\n",
        "    portfolio_history = {}\n",
        "    corporate_event_history = []\n",
        "    fixed_numsec_history = []\n",
        "\n",
        "    for rebalance_date in all_rebalance_dates:\n",
        "        if previous_date is not None and not current_portfolio.empty:\n",
        "            current_portfolio, event_log = apply_corporate_events(\n",
        "                current_portfolio,\n",
        "                events,\n",
        "                previous_date,\n",
        "                rebalance_date,\n",
        "            )\n",
        "\n",
        "            if not event_log.empty:\n",
        "                corporate_event_history.append(event_log)\n",
        "\n",
        "        parent_weight_dates = sorted(pd.to_datetime(list(parent_weights_by_date.keys())))\n",
        "        available_weight_dates = [d for d in parent_weight_dates if d <= rebalance_date]\n",
        "\n",
        "        if not available_weight_dates:\n",
        "            print(f\"Skipping {rebalance_date.date()}: no parent weights available\")\n",
        "            continue\n",
        "\n",
        "        weight_date = available_weight_dates[-1]\n",
        "        parent_weights = parent_weights_by_date[weight_date].dropna()\n",
        "\n",
        "        eligible_parent_weights = parent_weights[parent_weights.index.isin(prices.columns)]\n",
        "        parent_weights = eligible_parent_weights / eligible_parent_weights.sum()\n",
        "\n",
        "        eligible_tickers = [t for t in parent_weights.index if t in prices.columns]\n",
        "        rebalance_prices = prices.loc[:rebalance_date, eligible_tickers]\n",
        "\n",
        "        is_adhoc = pd.to_datetime(rebalance_date).normalize() in [\n",
        "            pd.to_datetime(d).normalize() for d in adhoc_dates\n",
        "        ]\n",
        "\n",
        "        if is_adhoc:\n",
        "            scores = calculate_adhoc_momentum_scores(\n",
        "                rebalance_prices,\n",
        "                rebalance_date,\n",
        "                ticker_country_map=ticker_country_map,\n",
        "                country_rf_rates=country_rf_rates,\n",
        "                default_risk_free_rate=default_risk_free_rate,\n",
        "            )\n",
        "        else:\n",
        "            scores = calculate_momentum_scores(\n",
        "                rebalance_prices,\n",
        "                rebalance_date,\n",
        "                ticker_country_map=ticker_country_map,\n",
        "                country_rf_rates=country_rf_rates,\n",
        "                default_risk_free_rate=default_risk_free_rate,\n",
        "            )\n",
        "\n",
        "        if scores.empty:\n",
        "            print(f\"Skipping {rebalance_date.date()}: insufficient score data\")\n",
        "            continue\n",
        "\n",
        "        selected, fixed_numsec = select_and_weight_portfolio(\n",
        "            scores=scores,\n",
        "            parent_weights=parent_weights,\n",
        "            previous_holdings=previous_holdings,\n",
        "            previous_fixed_numsec=previous_fixed_numsec,\n",
        "            previous_parent_numsec=previous_parent_numsec,\n",
        "            issuer_map=issuer_map,\n",
        "        )\n",
        "\n",
        "        portfolio_history[str(pd.to_datetime(rebalance_date).date())] = selected\n",
        "\n",
        "        fixed_numsec_history.append({\n",
        "            \"rebalance_date\": rebalance_date,\n",
        "            \"is_adhoc\": is_adhoc,\n",
        "            \"fixed_numsec\": fixed_numsec,\n",
        "            \"parent_numsec\": len(parent_weights),\n",
        "        })\n",
        "\n",
        "        current_portfolio = selected.copy()\n",
        "        previous_holdings = selected.index.tolist()\n",
        "        previous_fixed_numsec = fixed_numsec\n",
        "        previous_parent_numsec = len(parent_weights)\n",
        "        previous_date = rebalance_date\n",
        "\n",
        "    corporate_event_history = (\n",
        "        pd.concat(corporate_event_history, ignore_index=True)\n",
        "        if corporate_event_history else pd.DataFrame()\n",
        "    )\n",
        "\n",
        "    return {\n",
        "        \"portfolio_history\": portfolio_history,\n",
        "        \"corporate_event_history\": corporate_event_history,\n",
        "        \"vol_trigger_table\": vol_trigger_table,\n",
        "        \"adhoc_threshold\": adhoc_threshold,\n",
        "        \"adhoc_dates\": adhoc_dates,\n",
        "        \"scheduled_dates\": scheduled_dates,\n",
        "        \"all_rebalance_dates\": all_rebalance_dates,\n",
        "        \"fixed_numsec_history\": pd.DataFrame(fixed_numsec_history),\n",
        "    }"
      ],
      "id": "GQWKTAlqiJy9"
