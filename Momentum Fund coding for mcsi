      "source": [
        "# MSCI India Index data is not freely available via Yahoo Finance.\n",
        "# Therefore, the NIFTY 500 index (^CRSLDX) is used as a broad-market\n",
        "# proxy benchmark for the India-focused momentum strategy.\n",
        "\n",
        "def download_parent_index_prices(\n",
        "    ticker: str = \"^CRSLDX\", # NIFTY 500 Index\n",
        "    start: str = \"2016-01-01\",\n",
        "    end: Optional[str] = None,\n",
        ") -> pd.Series:\n",
        "\n",
        "    if end is None:\n",
        "        end = datetime.today().strftime(\"%Y-%m-%d\")\n",
        "\n",
        "    data = yf.download(\n",
        "        ticker,\n",
        "        start=start,\n",
        "        end=end,\n",
        "        auto_adjust=True, # this will automatically adjust for the corporate actions\n",
        "        progress=False,\n",
        "    )\n",
        "\n",
        "    if data.empty:\n",
        "        raise ValueError(\"Parent index data not downloaded. Try another ticker.\")\n",
        "\n",
        "    close = data[\"Close\"]\n",
        "    if isinstance(close, pd.DataFrame):\n",
        "        close = close.iloc[:, 0]\n",
        "    # this is to make it for 1 dimensional\n",
        "\n",
        "    return close.dropna()\n",
        "\n",
        "\n",
        "def calculate_t9_adhoc_volatility_table(\n",
        "    parent_prices: pd.Series,\n",
        "    calendar: str = \"XBOM\",\n",
        ") -> pd.DataFrame:\n",
        "\n",
        "    parent_prices = parent_prices.dropna().sort_index()\n",
        "    daily_returns = parent_prices.pct_change().dropna()\n",
        "\n",
        "    if daily_returns.empty:\n",
        "        return pd.DataFrame()\n",
        "\n",
        "    month_ends = get_month_end_dates(parent_prices.index.min(), parent_prices.index.max())\n",
        "    records = []\n",
        "\n",
        "    for month_end in month_ends:\n",
        "        previous_month_end = (month_end - pd.offsets.MonthEnd(1)).normalize()\n",
        "\n",
        "        if previous_month_end not in parent_prices.index:\n",
        "            available = parent_prices.index[parent_prices.index <= previous_month_end]\n",
        "            if len(available) == 0:\n",
        "                continue\n",
        "            previous_month_end = available[-1]\n",
        "\n",
        "        window_start = previous_month_end - pd.DateOffset(months=3)\n",
        "        window_returns = daily_returns[\n",
        "            (daily_returns.index > window_start) &\n",
        "            (daily_returns.index <= previous_month_end)\n",
        "        ]\n",
        "\n",
        "        if len(window_returns) < 40: # if this is less then skip bcz volatility for an small period will make the problem\n",
        "            continue\n",
        "\n",
        "        try:\n",
        "          # MSCI checks ad-hoc rebalance trigger at T-9 business days before month-end T where T-9 refers to the 9th previous trading/business session,\n",
        "          # not the 9th previous calendar day.\n",
        "            t_minus_9 = get_business_day_offset(month_end, -9, calendar=calendar)\n",
        "        except Exception:\n",
        "          # T-9 is calculated using valid trading sessions only, automatically skipping weekends and holidays.\n",
        "            available_dates = parent_prices.index[parent_prices.index <= month_end]\n",
        "            t_minus_9 = available_dates[-10]\n",
        "\n",
        "        annualized_vol = float(window_returns.std() * np.sqrt(250))\n",
        "\n",
        "        records.append({\n",
        "            \"Month End T\": month_end,\n",
        "            \"Trigger Check Date T-9\": t_minus_9,\n",
        "            \"Vol As Of Previous Month End\": previous_month_end,\n",
        "            \"Annualized Volatility\": annualized_vol,\n",
        "            \"Return Observations\": len(window_returns),\n",
        "        })\n",
        "\n",
        "    vol_df = pd.DataFrame(records)\n",
        "\n",
        "    if vol_df.empty:\n",
        "        return vol_df\n",
        "\n",
        "    vol_df[\"Volatility Change\"] = (\n",
        "        vol_df[\"Annualized Volatility\"] / vol_df[\"Annualized Volatility\"].shift(1)\n",
        "    ) - 1\n",
        "\n",
        "    return vol_df.dropna().reset_index(drop=True)\n",
        "\n",
        "\n",
        "def get_adhoc_rebalance_dates(\n",
        "    parent_prices: pd.Series,\n",
        "    threshold_percentile: float = 0.95,\n",
        "    calendar: str = \"XBOM\",\n",
        ") -> Tuple[List[pd.Timestamp], pd.DataFrame, float]:\n",
        "\n",
        "    vol_df = calculate_t9_adhoc_volatility_table(parent_prices, calendar=calendar)\n",
        "\n",
        "    if vol_df.empty:\n",
        "        return [], vol_df, np.nan\n",
        "\n",
        "    threshold = float(vol_df[\"Volatility Change\"].quantile(threshold_percentile))\n",
        "    vol_df[\"Adhoc Trigger\"] = vol_df[\"Volatility Change\"] > threshold\n",
        "\n",
        "    adhoc_dates = vol_df.loc[\n",
        "        vol_df[\"Adhoc Trigger\"],\n",
        "        \"Trigger Check Date T-9\"\n",
        "    ].tolist()\n",
        "\n",
        "    return adhoc_dates, vol_df, threshold"
      ],
      "id": "d8E49yskiJy8"
